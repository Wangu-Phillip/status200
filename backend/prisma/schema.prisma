generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String        @id @default(uuid())
  email        String        @unique
  password     String
  name         String
  userType     String        // "admin" | "client"
  adminLevel   String?       // "superadmin" | "admin" (only for admin userType)
  department   String?       // Required for adminLevel="admin", null for superadmin/client
  organization String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  address      String?
  phone        String?
  tier         String        @default("Tier 1 Citizen")
  trustScore   Int           @default(82)
  activities   ActivityLog[]
  applications Application[]
  complaints   Complaint[]
  tenders      Tender[]
  documents    Document[]

  @@map("users")
}

model Application {
  id              String     @id @default(uuid())
  userId          String
  referenceNumber String     @unique
  applicationType String
  businessName    String
  sector          String
  description     String
  status          String     @default("Submitted")
  department      String?    // "licensing", "complaints", "qos", "tenders"
  priority        String     @default("Medium")
  adminNotes      String?
  reviewedBy      String?
  reviewedAt      DateTime?
  submissionDate  DateTime   @default(now())
  lastUpdated     DateTime   @updatedAt
  createdAt       DateTime   @default(now())
  user            User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  documents       Document[]

  @@map("applications")
}

model Complaint {
  id               String     @id @default(uuid())
  userId           String
  ticketNumber     String     @unique
  complaintType    String
  complainantName  String
  complainantEmail String
  complainantPhone String
  description      String
  dateOfIncident   DateTime
  status           String     @default("Registered")
  againstOperator  String
  priority         String     @default("normal")
  department       String?    @default("complaints")  // "complaints"
  adminNotes       String?
  reviewedBy       String?
  reviewedAt       DateTime?
  registeredDate   DateTime   @default(now())
  lastUpdated      DateTime   @updatedAt
  createdAt        DateTime   @default(now())
  user             User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  documents        Document[]

  @@map("complaints")
}

model Tender {
  id                String     @id @default(uuid())
  userId            String
  tenderNumber      String     @unique
  title             String
  bidderName        String
  bidderEmail       String
  bidderPhone       String
  description       String
  estimatedValue    Float
  submittedAmount   Float
  status            String     @default("Submitted")
  department        String?    @default("tenders")  // "tenders"
  priority          String     @default("normal")
  adminNotes        String?
  reviewedBy        String?
  reviewedAt        DateTime?
  submissionDate    DateTime   @default(now())
  lastUpdated       DateTime   @updatedAt
  createdAt         DateTime   @default(now())
  user              User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  documents         Document[]

  @@map("tenders")
}

model TenderPosting {
  id              String     @id @default(uuid())
  tenderNumber    String     @unique
  title           String
  description     String
  status          String     @default("Open")  // "Open", "Closed", "Awarded"
  category        String     // Type of tender
  estimatedValue  Float?
  openingDate     DateTime   @default(now())
  closingDate     DateTime
  location        String?
  createdBy       String
  lastUpdatedBy   String?
  adminNotes      String?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  documents       TenderDocument[]

  @@map("tender_postings")
}

model TenderDocument {
  id              String     @id @default(uuid())
  tenderPostingId String
  filename        String
  fileType        String
  filePath        String
  fileSize        Int
  uploadedBy      String
  uploadedDate    DateTime   @default(now())
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  tenderPosting   TenderPosting @relation(fields: [tenderPostingId], references: [id], onDelete: Cascade)

  @@map("tender_documents")
}

model Document {
  id            String       @id @default(uuid())
  applicationId String?
  complaintId   String?
  tenderId      String?
  userId        String
  filename      String
  category      String
  documentType  String
  status        String       @default("pending_upload")
  uploadedDate  DateTime?
  expiryDate    DateTime?
  filePath      String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  application   Application? @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  complaint     Complaint?   @relation(fields: [complaintId], references: [id], onDelete: Cascade)
  tender        Tender?      @relation(fields: [tenderId], references: [id], onDelete: Cascade)
  user          User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("documents")
}

model ActivityLog {
  id          String   @id @default(uuid())
  userId      String
  action      String
  actionType  String
  description String
  entityId    String?
  ipAddress   String?
  device      String?
  status      String   @default("successful")
  timestamp   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("activity_logs")
}

model StatusCheck {
  id         String   @id @default(uuid())
  clientName String
  timestamp  DateTime @default(now())

  @@map("status_checks")
}

model TypeApprovedDevice {
  id                String   @id @default(uuid())
  deviceName        String
  manufacturer      String
  model             String
  certificateNumber String   @unique
  category          String
  approvalDate      DateTime
  expiryDate        DateTime
  standards         String
  status            String   @default("Active")
  frequency         String
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@map("type_approved_devices")
}

model SystemSettings {
  id                          String   @id @default(uuid())
  systemName                  String   @default("BOCRA Portal")
  systemDescription           String   @default("Botswana Communications Regulatory Authority Portal")
  maintenanceMode             Boolean  @default(false)
  passwordMinLength           Int      @default(8)
  passwordRequireSpecial      Boolean  @default(true)
  passwordExpireDays          Int      @default(90)
  sessionTimeoutMinutes       Int      @default(30)
  enableTwoFactor             Boolean  @default(false)
  emailNotificationsEnabled   Boolean  @default(true)
  emailOnNewSubmission        Boolean  @default(true)
  emailOnStatusChange         Boolean  @default(true)
  emailOnUserCreation         Boolean  @default(true)
  darkMode                    Boolean  @default(false)
  displayDensity              String   @default("normal")
  itemsPerPage                Int      @default(10)
  notificationsEnabled        Boolean  @default(true)
  enableBrowserNotifications  Boolean  @default(false)
  notificationSound           Boolean  @default(true)
  createdAt                   DateTime @default(now())
  updatedAt                   DateTime @updatedAt

  @@map("system_settings")
}
